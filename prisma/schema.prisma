// Prisma schema — GAME SHOP 221
// Supporte SQLite (local) et PostgreSQL (Vercel)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PRODUITS
// ============================================================
model Product {
  id              String   @id @default(cuid())
  name            String
  description     String
  price           Int
  oldPrice        Int?
  category        String
  game            String?
  emoji           String   @default("🎮")
  badge           String?
  popular         Boolean  @default(false)
  instantDelivery Boolean  @default(false)
  useUniqueCodes  Boolean  @default(false)
  deliveryContent String?
  deliveryTime    String?
  stock           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  codes  CodeItem[]
  orders Order[]

  @@index([category])
  @@index([active])
}

// ============================================================
// CODES UNIQUES (stock par produit)
// ============================================================
model CodeItem {
  id        String    @id @default(cuid())
  productId String
  content   String
  status    String    @default("available")
  orderId   String?   @unique
  createdAt DateTime  @default(now())
  soldAt    DateTime?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?

  @@index([productId, status])
  @@index([status])
}

// ============================================================
// COMMANDES
// ============================================================
model Order {
  id               String   @id @default(cuid())
  ref              String   @unique
  productId        String
  customerName     String?
  customerPhone    String?
  playerId         String?
  waveTxId         String?
  amount           Int
  status           String   @default("delivered")
  deliveredContent String?
  deliveredCodeId  String?  @unique
  createdAt        DateTime @default(now())

  product Product   @relation(fields: [productId], references: [id])
  code    CodeItem? @relation(fields: [deliveredCodeId], references: [id])

  @@index([ref])
  @@index([createdAt])
  @@index([status])
}
