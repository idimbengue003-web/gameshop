// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  description      String
  price            Int
  oldPrice         Int?
  category         String // "comptes" | "recharges" | "cartes"
  game             String?
  emoji            String   @default("🎮")
  badge            String?  // "PROMO" | "POPULAIRE" | "TOP VENTE" | "ÉCONOMIE"
  popular          Boolean  @default(false)
  instantDelivery  Boolean  @default(false)
  deliveryContent  String?  // code/compte affiché après paiement si instantDelivery
  deliveryTime     String?  // délai affiché si pas instantané (ex: "5-30 min", "24-48h")
  stock            Int      @default(0) // pour info, pas géré strictement
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([category])
  @@index([active])
}
